{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenClaw Pipeline Output",
  "type": "object",
  "required": ["contract_id", "generated_at", "nodes", "edges"],
  "properties": {
    "contract_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "timestamp", "source", "sentiment", "summary"],
        "properties": {
          "id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "source": { "type": "string" },
          "sentiment": { "type": "number", "minimum": -1, "maximum": 1 },
          "summary": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "kind": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
